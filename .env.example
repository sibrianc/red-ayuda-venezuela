FLASK_APP=wsgi.py
FLASK_ENV=development
SECRET_KEY=replace-with-a-long-random-value
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost/red_ayuda_venezuela
APP_NAME=Red de Ayuda Venezuela
APP_BASE_URL=http://127.0.0.1:5000
MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
ADMIN_EMAIL=

# SEO / compartir. SITE_URL es la base canónica absoluta para canonical, Open Graph,
# sitemap e IndexNow. En local déjalo vacío para usar el host de la petición.
SITE_URL=https://redayudave.org
# Verificación de propiedad (pega el token que te da cada herramienta). Vacío = sin meta.
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
# IndexNow (Bing/Yandex): genera una clave aleatoria (p. ej. uuid) y ponla aquí para
# que la ingesta avise automáticamente a los buscadores. Vacío = desactivado.
INDEXNOW_KEY=

# Operación autónoma (sin revisión humana). true = los reportes limpios y completos
# se publican solos; los que no pasan la verificación automática quedan en cola.
# Ponlo en false para exigir aprobación manual cuando haya personas revisando.
AUTO_PUBLISH=true

# Reenvío automático de la PROYECCIÓN PÚBLICA (sin datos privados) a una institución
# o flujo intermedio autorizado. Desactivado por defecto. Si lo activas, fija tu propio
# endpoint en INSTITUTION_WEBHOOK_URL.
INSTITUTION_FORWARD_ENABLED=false
INSTITUTION_WEBHOOK_URL=

# Rate limiting: storage en memoria por defecto. En producción multi-worker, usa Redis:
# RATELIMIT_STORAGE_URI=redis://localhost:6379
